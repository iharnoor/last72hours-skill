# Copy to .env and fill in values. NEVER commit a real .env.

# Required for Instagram + TikTok (paid; 10K free trial credits)
# https://scrapecreators.com
SCRAPECREATORS_API_KEY=

# Required for X — option 1: browser cookies (free)
# Get from x.com DevTools > Application > Cookies
AUTH_TOKEN=
CT0=

# Required for X — option 2: xAI API key (paid)
# XAI_API_KEY=

# Optional Bluesky
# BSKY_HANDLE=
# BSKY_APP_PASSWORD=

# Optional web-search backends
# BRAVE_API_KEY=
# OPENROUTER_API_KEY=

# Skill output dir (defaults to ~/Documents/Last72Hours)
# LAST72_OUTPUT_DIR=
